{
  "name": "belo-challenge",
  "version": "1.0.0",
  "description": "Mini Plataforma Fintech — Belo Backend Challenge",
  "main": "dist/server.js",
  "scripts": {
    "setup": "bash scripts/dev.sh",
    "dev": "bash scripts/dev.sh",
    "dev:local": "bash scripts/dev-local.sh",
    "dev:server": "tsx watch src/server.ts",
    "dev:all": "concurrently -n api,web -c green,cyan \"npm:dev:server\" \"npm:web:dev\"",
    "web:install": "npm --prefix web install",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:preview": "npm --prefix web run preview",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --runInBand --selectProjects unit integration smoke",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --runInBand --selectProjects integration",
    "test:smoke": "jest --runInBand --selectProjects smoke",
    "test:e2e": "jest --runInBand --selectProjects e2e",
    "test:all": "jest --runInBand",
    "test:watch": "jest --watch --runInBand --selectProjects unit integration",
    "db:migrate": "knex migrate:latest --knexfile knexfile.ts",
    "db:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "db:seed": "knex seed:run --knexfile knexfile.ts",
    "db:reset": "knex migrate:rollback --all --knexfile knexfile.ts && knex migrate:latest --knexfile knexfile.ts && knex seed:run --knexfile knexfile.ts",
    "db:promote-admin": "tsx scripts/promote-admin.ts",
    "prepare": "husky",
    "postinstall": "npm --prefix web install"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "decimal.js": "^10.4.3",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "knex": "^3.1.0",
    "objection": "^3.1.5",
    "pg": "^8.13.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
